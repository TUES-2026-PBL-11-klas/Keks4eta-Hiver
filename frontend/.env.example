# Frontend (Vite) environment — copy to frontend/.env
# Only VITE_-prefixed vars are exposed to the browser bundle.

# API base path/URL the SPA calls. Defaults to "/api/v1" (Vite dev-proxies to the backend).
# Set to the backend's public URL when the frontend is deployed separately.
# VITE_API_BASE=/api/v1

# Google Maps Platform browser key — powers the Nearby-Hivers map pins and the
# Post-a-task address autocomplete. Provision at https://console.cloud.google.com/:
#   enable "Maps JavaScript API" + "Places API", create a browser API key,
#   restrict it to your origins (http://localhost:5173 + prod), and enable billing.
# Leave blank to fall back to a free OpenStreetMap embed + plain text location input.
VITE_GOOGLE_MAPS_KEY=

# Optional cloud Map ID (enables AdvancedMarker styling). Defaults to "DEMO_MAP_ID".
# VITE_GOOGLE_MAPS_MAP_ID=
