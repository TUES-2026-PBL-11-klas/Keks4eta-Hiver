# Database
# Creds below match docker-compose.yml (user=hiver, pass=hiver_password, db=hiver).
# Host = localhost when running the backend on your machine (port is published).
# Host = postgres   when running the backend INSIDE docker compose (service name).
DATABASE_URL=postgresql+asyncpg://hiver:hiver_password@localhost:5432/hiver
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_USE_POOLER=false
# ── SHARED CLOUD DB (so the whole team uses one database) ────────────────────
# Create a free Supabase project, then Dashboard → Connect → "Transaction pooler"
# and use that URL here (note the +asyncpg driver and the trailing options).
# Set DATABASE_USE_POOLER=true when using a pooler (port 6543). See docs/CLOUD_SETUP.md.
#   DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres
#   DATABASE_USE_POOLER=true

# Redis
# Password matches docker-compose.yml. Host = localhost on host, redis inside compose.
REDIS_URL=redis://:redis_password@localhost:6379/0

# Auth
# Required. Generate: openssl rand -hex 32   OR   python -c "import secrets;print(secrets.token_hex(32))"
JWT_SECRET_KEY=          # min 32 chars
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# Social login (OAuth). Leave a provider's pair blank to disable it.
# Google:   https://console.cloud.google.com/apis/credentials  (OAuth client, type "Web application")
#           Authorized redirect URI: http://localhost:8000/api/v1/auth/oauth/google/callback
# Facebook: https://developers.facebook.com/apps  (Facebook Login product)
#           Valid OAuth Redirect URI: http://localhost:8000/api/v1/auth/oauth/facebook/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
# Base URL the provider redirects back to (must match the console). Provider + /callback appended.
OAUTH_REDIRECT_BASE_URL=http://localhost:8000
# SPA route the backend redirects to after login (carries tokens in the URL fragment).
FRONTEND_URL=http://localhost:5173

# Stripe (Test Mode only for development)
# Required by config to boot — dummy values are fine until you exercise the payment flow.
STRIPE_SECRET_KEY=sk_test_dummy
STRIPE_WEBHOOK_SECRET=whsec_dummy

# Google Maps
GOOGLE_MAPS_API_KEY=

# Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Firebase (push notifications)
FIREBASE_CREDENTIALS_JSON=

# App
APP_ENV=development        # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=DEBUG            # DEBUG | INFO | WARNING | ERROR
CORS_ORIGINS=http://localhost:5173
